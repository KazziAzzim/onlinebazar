@{ ViewData["Title"] = "Login"; }
<h1>Login</h1>
<form method="post" class="row g-3 col-md-6">
    <div><label>Email</label><input class="form-control" name="email" type="email" required /></div>
    <div><label>Password</label><input class="form-control" name="password" type="password" required /></div>
    <div><button class="btn btn-dark" type="submit">Sign In</button></div>
</form>
