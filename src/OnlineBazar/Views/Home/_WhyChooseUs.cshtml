@{
    var trustIndicators = new[]
    {
        new { Key = "pickup", Title = "Free Pickup", Description = "Collect your order quickly from nearby pickup points at no extra cost." },
        new { Key = "payment", Title = "Instant Payment", Description = "Fast checkout with immediate confirmations across trusted payment methods." },
        new { Key = "verified", Title = "Verified Products", Description = "Every listing is quality-checked and verified before it reaches customers." },
        new { Key = "warranty", Title = "Warranty Available", Description = "Selected products include warranty coverage for added peace of mind." },
        new { Key = "secure", Title = "Secure Transactions", Description = "Your personal data and payments are protected by modern security standards." },
        new { Key = "support", Title = "Customer Support", Description = "Our support team is ready to help with orders, returns, and product questions." }
    };
}

<section class="home-section trust-indicators-section" aria-labelledby="whyChooseUsTitle">
    <div class="home-section-header trust-indicators-header mb-3">
        <h2 id="whyChooseUsTitle" class="h4 mb-0">Why Choose Us</h2>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-4 g-3 g-lg-4">
        @foreach (var indicator in trustIndicators)
        {
            <div class="col d-flex">
                <article class="trust-indicator-card text-center w-100">
                    <div class="trust-indicator-icon-wrap" aria-hidden="true">
                        @switch (indicator.Key)
                        {
                            case "pickup":
                                <svg viewBox="0 0 24 24" class="trust-indicator-icon" role="img" focusable="false">
                                    <path d="M2.5 5.5h11v8h-11zM13.5 8.5h4.2l2.3 2.8v2.2h-6.5zM6.5 16a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3Zm10 0a1.5 1.5 0 1 1 0 3 1.5 1.5 0 0 1 0-3Z" />
                                </svg>
                                break;
                            case "payment":
                                <svg viewBox="0 0 24 24" class="trust-indicator-icon" role="img" focusable="false">
                                    <path d="M3 7.5A2.5 2.5 0 0 1 5.5 5h13A2.5 2.5 0 0 1 21 7.5v9a2.5 2.5 0 0 1-2.5 2.5h-13A2.5 2.5 0 0 1 3 16.5v-9Zm2 1v2h14v-2a.5.5 0 0 0-.5-.5h-13a.5.5 0 0 0-.5.5Zm4 6h4a1 1 0 1 1 0 2H9a1 1 0 1 1 0-2Z" />
                                </svg>
                                break;
                            case "verified":
                                <svg viewBox="0 0 24 24" class="trust-indicator-icon" role="img" focusable="false">
                                    <path d="M12 2.5 4.5 5.7v5.1c0 5 3.2 9.6 7.5 10.7 4.3-1.1 7.5-5.7 7.5-10.7V5.7L12 2.5Zm3.4 7.8-4.1 4.1a1 1 0 0 1-1.4 0l-1.8-1.8a1 1 0 1 1 1.4-1.4l1.1 1.1 3.4-3.4a1 1 0 0 1 1.4 1.4Z" />
                                </svg>
                                break;
                            case "warranty":
                                <svg viewBox="0 0 24 24" class="trust-indicator-icon" role="img" focusable="false">
                                    <path d="M12 2.2 5 4.8v6c0 5.1 2.9 9.5 7 11 4.1-1.5 7-5.9 7-11v-6l-7-2.6Zm3.8 8.9-4.7 4.7a1 1 0 0 1-1.4 0l-2.3-2.3a1 1 0 0 1 1.4-1.4l1.6 1.6 4-4a1 1 0 1 1 1.4 1.4Z" />
                                </svg>
                                break;
                            case "secure":
                                <svg viewBox="0 0 24 24" class="trust-indicator-icon" role="img" focusable="false">
                                    <path d="M12 2a5 5 0 0 0-5 5v3H6a2 2 0 0 0-2 2v7a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2v-7a2 2 0 0 0-2-2h-1V7a5 5 0 0 0-5-5Zm-3 8V7a3 3 0 1 1 6 0v3H9Zm3 3a2 2 0 0 1 1 3.7V18a1 1 0 1 1-2 0v-1.3A2 2 0 0 1 12 13Z" />
                                </svg>
                                break;
                            default:
                                <svg viewBox="0 0 24 24" class="trust-indicator-icon" role="img" focusable="false">
                                    <path d="M12 2.5a9.5 9.5 0 1 0 0 19 9.5 9.5 0 0 0 0-19Zm4.1 8.1-4.7 4.7a1 1 0 0 1-1.4 0l-2-2a1 1 0 0 1 1.4-1.4l1.3 1.3 4-4a1 1 0 0 1 1.4 1.4Z" />
                                </svg>
                                break;
                        }
                    </div>
                    <h3 class="trust-indicator-title">@indicator.Title</h3>
                    <p class="trust-indicator-description mb-0">@indicator.Description</p>
                </article>
            </div>
        }
    </div>
</section>
