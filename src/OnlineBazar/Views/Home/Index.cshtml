@model OnlineBazar.ViewModels.HomeViewModel

@{
    ViewData["Title"] = "Home";
}

<section id="homeBannerCarousel" class="carousel slide shadow-sm rounded overflow-hidden" data-bs-ride="carousel">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#homeBannerCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Banner 1"></button>
        <button type="button" data-bs-target="#homeBannerCarousel" data-bs-slide-to="1" aria-label="Banner 2"></button>
        <button type="button" data-bs-target="#homeBannerCarousel" data-bs-slide-to="2" aria-label="Banner 3"></button>
    </div>
    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="~/images/carousel/fashion-1.svg" class="d-block w-100" alt="Spring collection banner" />
        </div>
        <div class="carousel-item">
            <img src="~/images/carousel/fashion-2.svg" class="d-block w-100" alt="New arrivals banner" />
        </div>
        <div class="carousel-item">
            <img src="~/images/carousel/fashion-3.svg" class="d-block w-100" alt="Discount offers banner" />
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#homeBannerCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#homeBannerCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
    </button>
</section>

<section class="mt-5">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h4 mb-0">What Our Customers Say</h2>
    </div>
    <div id="testimonialsGrid" class="row g-3 testimonials-grid" aria-live="polite"></div>
</section>

@section Scripts {
    <script>
        (() => {
            const testimonialsGrid = document.getElementById("testimonialsGrid");
            if (!testimonialsGrid) return;

            const renderPlaceholders = () => {
                const placeholderCards = Array.from({ length: 6 }, () => `
                    <div class="col-12 col-sm-6 col-lg-4 d-flex">
                        <article class="card testimonials-card h-100 w-100" aria-hidden="true">
                            <div class="card-body d-flex flex-column">
                                <div class="placeholder-glow mb-3">
                                    <span class="placeholder col-5"></span>
                                </div>
                                <p class="card-text testimonial-review placeholder-glow">
                                    <span class="placeholder col-12"></span>
                                    <span class="placeholder col-11"></span>
                                    <span class="placeholder col-9"></span>
                                </p>
                                <div class="mt-auto placeholder-glow">
                                    <span class="placeholder col-7"></span>
                                </div>
                            </div>
                        </article>
                    </div>`);

                testimonialsGrid.innerHTML = placeholderCards.join("");
            };

            const getStarsMarkup = (rating) => {
                const maxStars = 5;
                return Array.from({ length: maxStars }, (_, idx) =>
                    `<span class="testimonial-star ${idx < rating ? "is-filled" : ""}" aria-hidden="true">★</span>`
                ).join("");
            };

            const renderTestimonials = (testimonials) => {
                if (!Array.isArray(testimonials) || testimonials.length === 0) {
                    testimonialsGrid.innerHTML = "";
                    return;
                }

                testimonialsGrid.innerHTML = testimonials.map((item) => `
                    <div class="col-12 col-sm-6 col-lg-4 d-flex">
                        <article class="card testimonials-card h-100 w-100">
                            <div class="card-body d-flex flex-column">
                                <div class="testimonial-stars mb-3" aria-label="${item.rating} out of 5 stars">
                                    ${getStarsMarkup(item.rating)}
                                </div>
                                <p class="card-text testimonial-review">${item.reviewText}</p>
                                <p class="testimonial-meta mt-auto mb-0">
                                    <span class="testimonial-customer">${item.customerName}</span>
                                    <span class="testimonial-city">, ${item.city}</span>
                                </p>
                            </div>
                        </article>
                    </div>`).join("");
            };

            renderPlaceholders();

            fetch("/api/testimonials", { headers: { "Accept": "application/json" } })
                .then(response => response.ok ? response.json() : [])
                .then(data => renderTestimonials(data))
                .catch(() => {
                    testimonialsGrid.innerHTML = "";
                });
        })();
    </script>
}

<section class="mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h4 mb-0">Featured Products</h2>
        <a asp-controller="Products" asp-action="Index" class="btn btn-outline-dark btn-sm d-inline-flex align-items-center gap-2">
            <span>View More</span>
            <span aria-hidden="true">&rarr;</span>
        </a>
    </div>

    <div class="featured-products-row pb-2">
        @foreach (var product in Model.FeaturedProducts)
        {
            var discountPercentage = 20 + (product.Id % 5) * 5;
            var originalPrice = Math.Round(product.Price / (1 - (discountPercentage / 100m)), 2);
            var productDescription = string.IsNullOrWhiteSpace(product.Description) ? "Everyday Wear" : product.Description.Trim();
            const int descriptionLimit = 80;
            var isDescriptionTruncated = productDescription.Length > descriptionLimit;
            var truncatedDescription = isDescriptionTruncated
                ? $"{productDescription[..descriptionLimit].TrimEnd()}..."
                : productDescription;

            <article class="card product-card featured-product-card h-100">
                <div class="featured-product-image-wrap">
                    <img src="@(string.IsNullOrWhiteSpace(product.ImageUrl) ? Url.Content("~/images/carousel/fashion-1.svg") : product.ImageUrl)"
                         class="card-img-top product-card-image featured-product-image"
                         alt="@product.Name" />
                    <span class="featured-product-discount">-@discountPercentage%</span>
                </div>
                <div class="card-body featured-product-body d-flex flex-column">
                    <h3 class="h5 product-card-title featured-product-title">@product.Name</h3>
                    <p class="featured-product-category mb-3">
                        <span>@truncatedDescription</span>
                        @if (isDescriptionTruncated)
                        {
                            <a asp-controller="Products"
                               asp-action="Details"
                               asp-route-id="@product.Id"
                               class="featured-product-more-link ms-1">More</a>
                        }
                    </p>

                    <div class="mt-auto mb-3">
                        <span class="featured-product-old-price me-2">$@originalPrice.ToString("0.00")</span>
                        <span class="featured-product-price">$@product.Price.ToString("0.00")</span>
                    </div>

                    @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Customer"))
                    {
                        <form asp-controller="Cart" asp-action="Add" method="post" class="d-grid">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="productId" value="@product.Id" />
                            <input type="hidden" name="quantity" value="1" />
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                            <button type="submit" class="btn featured-product-cta">ADD TO CART</button>
                        </form>
                    }
                    else
                    {
                        <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id" class="btn featured-product-cta">VIEW PRODUCT</a>
                    }
                </div>
            </article>
        }
    </div>
</section>

<section class="mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h4 mb-0">What Our Customers Say</h2>
    </div>

    <div class="row g-3">
        <div class="col-12 col-md-6 col-lg-4">
            <article class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <p class="mb-3 text-secondary">“Great quality and fast delivery. The checkout experience was smooth and simple.”</p>
                    <h3 class="h6 mb-0">Ava Martinez</h3>
                </div>
            </article>
        </div>
        <div class="col-12 col-md-6 col-lg-4">
            <article class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <p class="mb-3 text-secondary">“I found exactly what I needed at a fair price. Product images matched what arrived.”</p>
                    <h3 class="h6 mb-0">Noah Johnson</h3>
                </div>
            </article>
        </div>
        <div class="col-12 col-md-6 col-lg-4">
            <article class="card h-100 border-0 shadow-sm">
                <div class="card-body">
                    <p class="mb-3 text-secondary">“Customer support was responsive and helpful. I’ll definitely shop here again.”</p>
                    <h3 class="h6 mb-0">Sophia Lee</h3>
                </div>
            </article>
        </div>
    </div>
</section>
