@model OnlineBazar.ViewModels.HomeViewModel

@{
    ViewData["Title"] = "Home";
}

<div class="home-page">
<section id="homeBannerCarousel" class="carousel slide shadow-sm rounded overflow-hidden home-hero-carousel" data-bs-ride="carousel">
    @{
        var dynamicBanners = Model.Banners.ToList();
        var fallbackBanners = new[]
        {
            new { ImageUrl = Url.Content("~/images/carousel/fashion-1.svg"), Title = "Spring collection banner", Subtitle = string.Empty, RedirectUrl = string.Empty },
            new { ImageUrl = Url.Content("~/images/carousel/fashion-2.svg"), Title = "New arrivals banner", Subtitle = string.Empty, RedirectUrl = string.Empty },
            new { ImageUrl = Url.Content("~/images/carousel/fashion-3.svg"), Title = "Discount offers banner", Subtitle = string.Empty, RedirectUrl = string.Empty }
        };
        var hasDynamicBanners = dynamicBanners.Count > 0;
        var bannerItems = hasDynamicBanners
            ? dynamicBanners.Select(b => new { b.ImageUrl, b.Title, b.Subtitle, b.RedirectUrl }).ToList()
            : fallbackBanners.Select(b => new { b.ImageUrl, b.Title, b.Subtitle, b.RedirectUrl }).ToList();
    }

    <div class="carousel-indicators">
        @for (var i = 0; i < bannerItems.Count; i++)
        {
            <button type="button"
                    data-bs-target="#homeBannerCarousel"
                    data-bs-slide-to="@i"
                    class="@(i == 0 ? "active" : string.Empty)"
                    aria-current="@(i == 0 ? "true" : "false")"
                    aria-label="Banner @(i + 1)"></button>
        }
    </div>
    <div class="carousel-inner">
        @for (var i = 0; i < bannerItems.Count; i++)
        {
            var banner = bannerItems[i];
            var hasContent = !string.IsNullOrWhiteSpace(banner.Title) || !string.IsNullOrWhiteSpace(banner.Subtitle);
            <div class="carousel-item @(i == 0 ? "active" : string.Empty)">
                @if (!string.IsNullOrWhiteSpace(banner.RedirectUrl))
                {
                    <a href="@banner.RedirectUrl" class="home-banner-link">
                        <img src="@banner.ImageUrl" class="d-block w-100" alt="@(string.IsNullOrWhiteSpace(banner.Title) ? $"Homepage banner {i + 1}" : banner.Title)" />
                        @if (hasContent)
                        {
                            <div class="home-banner-overlay">
                                @if (!string.IsNullOrWhiteSpace(banner.Title))
                                {
                                    <h2 class="home-banner-title">@banner.Title</h2>
                                }
                                @if (!string.IsNullOrWhiteSpace(banner.Subtitle))
                                {
                                    <p class="home-banner-subtitle mb-0">@banner.Subtitle</p>
                                }
                            </div>
                        }
                    </a>
                }
                else
                {
                    <img src="@banner.ImageUrl" class="d-block w-100" alt="@(string.IsNullOrWhiteSpace(banner.Title) ? $"Homepage banner {i + 1}" : banner.Title)" />
                    @if (hasContent)
                    {
                        <div class="home-banner-overlay">
                            @if (!string.IsNullOrWhiteSpace(banner.Title))
                            {
                                <h2 class="home-banner-title">@banner.Title</h2>
                            }
                            @if (!string.IsNullOrWhiteSpace(banner.Subtitle))
                            {
                                <p class="home-banner-subtitle mb-0">@banner.Subtitle</p>
                            }
                        </div>
                    }
                }
            </div>
        }
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#homeBannerCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#homeBannerCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
    </button>
</section>


<section class="home-section">
    <div class="home-section-header mb-3">
        <h2 class="h4 mb-0">Featured Products</h2>
        <a asp-controller="Products" asp-action="Index" class="btn btn-outline-dark btn-sm d-inline-flex align-items-center gap-2 home-section-link">
            <span>View More</span>
            <span aria-hidden="true">&rarr;</span>
        </a>
    </div>

    <div id="featuredProductsCarousel" class="featured-products-carousel pb-2" data-autoplay-ms="4000" aria-label="Featured products slider">
        <button type="button" class="featured-carousel-control featured-carousel-control-prev" data-direction="prev" aria-label="Previous featured products">
            <span aria-hidden="true">&#10094;</span>
        </button>

        <div class="featured-products-viewport">
            <div class="featured-products-row">
                @foreach (var product in Model.FeaturedProducts)
                {
            var discountPercentage = 20 + (product.Id % 5) * 5;
            var originalPrice = Math.Round(product.Price / (1 - (discountPercentage / 100m)), 2);
            var productDescription = string.IsNullOrWhiteSpace(product.Description) ? "Everyday Wear" : product.Description.Trim();
            const int descriptionLimit = 80;
            var isDescriptionTruncated = productDescription.Length > descriptionLimit;
            var truncatedDescription = isDescriptionTruncated
                ? $"{productDescription[..descriptionLimit].TrimEnd()}..."
                : productDescription;

                    <div class="featured-product-slide">
                        <article class="card product-card featured-product-card h-100">
                            <div class="featured-product-image-wrap">
                                <img src="@(string.IsNullOrWhiteSpace(product.ImageUrl) ? Url.Content("~/images/carousel/fashion-1.svg") : product.ImageUrl)"
                                     class="card-img-top product-card-image featured-product-image"
                                     alt="@product.Name" />
                                <span class="featured-product-discount">-@discountPercentage%</span>
                            </div>
                            <div class="card-body featured-product-body d-flex flex-column">
                                <h3 class="h5 product-card-title featured-product-title">@product.Name</h3>
                                <p class="featured-product-category mb-3">
                                    <span>@truncatedDescription</span>
                                    @if (isDescriptionTruncated)
                                    {
                                        <a asp-controller="Products"
                                           asp-action="Details"
                                           asp-route-id="@product.Id"
                                           class="featured-product-more-link ms-1">More</a>
                                    }
                                </p>

                                <div class="mt-auto mb-3">
                                    <span class="featured-product-old-price me-2">$@originalPrice.ToString("0.00")</span>
                                    <span class="featured-product-price">$@product.Price.ToString("0.00")</span>
                                </div>

                                @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Customer"))
                                {
                                    <form asp-controller="Cart" asp-action="Add" method="post" class="d-grid">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="productId" value="@product.Id" />
                                        <input type="hidden" name="quantity" value="1" />
                                        <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                        <button type="submit" class="btn featured-product-cta">ADD TO CART</button>
                                    </form>
                                }
                                else
                                {
                                    <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id" class="btn featured-product-cta">VIEW PRODUCT</a>
                                }
                            </div>
                        </article>
                    </div>
                }
            </div>
        </div>

        <button type="button" class="featured-carousel-control featured-carousel-control-next" data-direction="next" aria-label="Next featured products">
            <span aria-hidden="true">&#10095;</span>
        </button>

        <div class="featured-carousel-dots" aria-hidden="true"></div>
    </div>
</section>

