@if (Model.Deals.Any())
{
    <section class="home-section">
        <div class="home-section-header mb-3">
            <h2 class="h4 mb-0">🔥 Today’s Deals</h2>
        </div>

        <div class="row g-3 deals-grid">
            @foreach (var deal in Model.Deals)
            {
                var fallbackImage = Url.Content("~/images/carousel/fashion-2.svg");
                var normalizedDiscountType = (deal.DiscountType ?? string.Empty).Trim().ToLowerInvariant();
                var discountLabel = normalizedDiscountType == "percentage"
                    ? $"{deal.DiscountValue:0.##}% OFF"
                    : $"Flat ₹{deal.DiscountValue:0.##} OFF";
                <div class="col-12 col-md-6 col-xl-3 d-flex">
                    <article class="card deal-card h-100 w-100" data-deal-card data-end-date="@deal.EndDate.ToString("o")">
                        <div class="deal-image-wrap">
                            <img src="@(string.IsNullOrWhiteSpace(deal.ImageUrl) ? fallbackImage : deal.ImageUrl)"
                                 class="deal-image"
                                 alt="@deal.Title" />
                            <span class="badge rounded-pill deal-badge">Limited Time</span>
                        </div>
                        <div class="card-body d-flex flex-column">
                            <h3 class="h5 mb-2 deal-title">@deal.Title</h3>
                            <p class="deal-discount-label mb-2">@discountLabel</p>
                            @if (!string.IsNullOrWhiteSpace(deal.Description))
                            {
                                <p class="deal-description mb-3">@deal.Description</p>
                            }
                            <div class="deal-timer mb-3" data-deal-timer>00:00:00</div>
                            <a href="@(string.IsNullOrWhiteSpace(deal.RedirectUrl) ? Url.Action("Index", "Products") : deal.RedirectUrl)"
                               class="btn deal-cta mt-auto">
                                Shop Now
                            </a>
                        </div>
                    </article>
                </div>
            }
        </div>
    </section>
}

<section class="home-section">
    <div class="home-section-header mb-3">
        <h2 class="h4 mb-0">What Our Customers Say</h2>
    </div>
    <div id="testimonialsGrid" class="row g-3 testimonials-grid" aria-live="polite"></div>
</section>

<partial name="_WhyChooseUs" />
</div>

@section Scripts {
    <script>
        (() => {
            const carousels = document.querySelectorAll(".featured-products-carousel");
            carousels.forEach(carousel => {
                const track = carousel.querySelector(".featured-products-row");
                const slides = Array.from(carousel.querySelectorAll(".featured-product-slide"));
                const prevButton = carousel.querySelector('[data-direction="prev"]');
                const nextButton = carousel.querySelector('[data-direction="next"]');
                const dotsContainer = carousel.querySelector(".featured-carousel-dots");
                const autoplayInterval = Number.parseInt(carousel.dataset.autoplayMs ?? "4000", 10);

                if (track && slides.length > 0) {
                    let itemsPerView = 1;
                    let currentIndex = 0;
                    let maxIndex = 0;
                    let autoplayTimer = null;
                    let dots = [];

                    const getItemsPerView = () => {
                        const width = window.innerWidth;
                        if (width >= 1400) return 5;
                        if (width >= 1200) return 4;
                        if (width >= 992) return 3;
                        if (width >= 576) return 2;
                        return 1;
                    };

                    const setTransform = () => {
                        const activeSlide = slides[currentIndex];
                        const offset = activeSlide ? activeSlide.offsetLeft : 0;
                        track.style.transform = `translate3d(${-offset}px, 0, 0)`;
                    };

                    const updateControls = () => {
                        dots.forEach((dot, idx) => {
                            const isActive = idx === currentIndex;
                            dot.classList.toggle("is-active", isActive);
                            dot.setAttribute("aria-current", isActive ? "true" : "false");
                        });
                    };

                    const goToSlide = (nextIndex) => {
                        currentIndex = Math.min(Math.max(nextIndex, 0), maxIndex);
                        setTransform();
                        updateControls();
                    };

                    const step = (direction) => {
                        const target = direction === "next"
                            ? (currentIndex >= maxIndex ? 0 : currentIndex + 1)
                            : (currentIndex <= 0 ? maxIndex : currentIndex - 1);
                        goToSlide(target);
                    };

                    const buildDots = () => {
                        if (!dotsContainer) return;

                        const pages = maxIndex + 1;
                        dotsContainer.innerHTML = Array.from({ length: pages }, (_, idx) =>
                            `<button type="button" class="featured-carousel-dot ${idx === currentIndex ? "is-active" : ""}" data-slide="${idx}" aria-label="Go to featured products slide ${idx + 1}" aria-current="${idx === currentIndex}"></button>`
                        ).join("");

                        dotsContainer.hidden = pages <= 1;

                        dots = Array.from(dotsContainer.querySelectorAll(".featured-carousel-dot"));
                        dots.forEach(dot => {
                            dot.addEventListener("click", () => {
                                const slideIndex = Number.parseInt(dot.dataset.slide ?? "0", 10);
                                goToSlide(slideIndex);
                            });
                        });
                    };

                    const recalculate = () => {
                        itemsPerView = Math.min(getItemsPerView(), slides.length);
                        maxIndex = Math.max(0, slides.length - itemsPerView);
                        carousel.style.setProperty("--featured-items-per-view", `${itemsPerView}`);
                        currentIndex = Math.min(currentIndex, maxIndex);
                        buildDots();
                        setTransform();
                        updateControls();
                    };

                    const startAutoplay = () => {
                        if (autoplayTimer || slides.length <= itemsPerView) return;
                        autoplayTimer = window.setInterval(() => step("next"), autoplayInterval);
                    };

                    const stopAutoplay = () => {
                        if (!autoplayTimer) return;
                        window.clearInterval(autoplayTimer);
                        autoplayTimer = null;
                    };

                    prevButton?.addEventListener("click", () => step("prev"));
                    nextButton?.addEventListener("click", () => step("next"));

                    carousel.addEventListener("mouseenter", stopAutoplay);
                    carousel.addEventListener("mouseleave", startAutoplay);
                    carousel.addEventListener("focusin", stopAutoplay);
                    carousel.addEventListener("focusout", (event) => {
                        if (!carousel.contains(event.relatedTarget)) {
                            startAutoplay();
                        }
                    });

                    window.addEventListener("resize", recalculate);

                    recalculate();
                    startAutoplay();
                }
            });

            const dealCards = Array.from(document.querySelectorAll("[data-deal-card]"));
            if (dealCards.length > 0) {
                const formatTimer = (milliseconds) => {
                    if (milliseconds <= 0) {
                        return "00:00:00";
                    }

                    const totalSeconds = Math.floor(milliseconds / 1000);
                    const hours = Math.floor(totalSeconds / 3600);
                    const minutes = Math.floor((totalSeconds % 3600) / 60);
                    const seconds = totalSeconds % 60;

                    return [hours, minutes, seconds]
                        .map(value => value.toString().padStart(2, "0"))
                        .join(":");
                };

                const updateDealTimers = () => {
                    const now = Date.now();
                    dealCards.forEach(card => {
                        const timerElement = card.querySelector("[data-deal-timer]");
                        const endDateRaw = card.getAttribute("data-end-date");
                        const endTime = endDateRaw ? new Date(endDateRaw).getTime() : Number.NaN;

                        if (!timerElement || Number.isNaN(endTime)) {
                            return;
                        }

                        const remainingTime = endTime - now;
                        if (remainingTime <= 0) {
                            timerElement.textContent = "Expired";
                            card.classList.add("deal-expired");
                            window.setTimeout(() => card.classList.add("d-none"), 1500);
                            return;
                        }

                        timerElement.textContent = formatTimer(remainingTime);
                    });
                };

                updateDealTimers();
                window.setInterval(updateDealTimers, 1000);
            }

            const testimonialsGrid = document.getElementById("testimonialsGrid");
            if (!testimonialsGrid) return;

            const renderPlaceholders = () => {
                const placeholderCards = Array.from({ length: 6 }, () => `
                    <div class="col-12 col-sm-6 col-lg-4 d-flex">
                        <article class="card testimonials-card h-100 w-100" aria-hidden="true">
                            <div class="card-body d-flex flex-column">
                                <div class="placeholder-glow mb-3">
                                    <span class="placeholder col-5"></span>
                                </div>
                                <p class="card-text testimonial-review placeholder-glow">
                                    <span class="placeholder col-12"></span>
                                    <span class="placeholder col-11"></span>
                                    <span class="placeholder col-9"></span>
                                </p>
                                <div class="mt-auto placeholder-glow">
                                    <span class="placeholder col-7"></span>
                                </div>
                            </div>
                        </article>
                    </div>`);

                testimonialsGrid.innerHTML = placeholderCards.join("");
            };

            const getStarsMarkup = (rating) => {
                const maxStars = 5;
                return Array.from({ length: maxStars }, (_, idx) =>
                    `<span class="testimonial-star ${idx < rating ? "is-filled" : ""}" aria-hidden="true">★</span>`
                ).join("");
            };

            const renderTestimonials = (testimonials) => {
                if (!Array.isArray(testimonials) || testimonials.length === 0) {
                    testimonialsGrid.innerHTML = "";
                    return;
                }

                testimonialsGrid.innerHTML = testimonials.map((item) => `
                    <div class="col-12 col-sm-6 col-lg-4 d-flex">
                        <article class="card testimonials-card h-100 w-100">
                            <div class="card-body d-flex flex-column">
                                <div class="testimonial-stars mb-3" aria-label="${item.rating} out of 5 stars">
                                    ${getStarsMarkup(item.rating)}
                                </div>
                                <p class="card-text testimonial-review">${item.reviewText}</p>
                                <p class="testimonial-meta mt-auto mb-0">
                                    <span class="testimonial-customer">${item.customerName}</span>
                                    <span class="testimonial-city">, ${item.city}</span>
                                </p>
                            </div>
                        </article>
                    </div>`).join("");
            };

            renderPlaceholders();

            fetch("/api/testimonials", { headers: { "Accept": "application/json" } })
                .then(response => response.ok ? response.json() : [])
                .then(data => renderTestimonials(data))
                .catch(() => {
                    testimonialsGrid.innerHTML = "";
                });
        })();
    </script>
}
