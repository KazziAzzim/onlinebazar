@model HomeViewModel
@{
    ViewData["Title"] = "Home";
    var carouselProducts = Model.CarouselProducts.ToList();
}

@if (carouselProducts.Any())
{
    <section id="productCarousel" class="carousel slide mb-4 shadow-sm rounded overflow-hidden" data-bs-ride="carousel">
        <div class="carousel-indicators">
            @for (var i = 0; i < carouselProducts.Count; i++)
            {
                <button type="button" data-bs-target="#productCarousel" data-bs-slide-to="@i" class="@(i == 0 ? "active" : string.Empty)" aria-current="@(i == 0 ? "true" : "false")" aria-label="Slide @(i + 1)"></button>
            }
        </div>
        <div class="carousel-inner">
            @for (var i = 0; i < carouselProducts.Count; i++)
            {
                var item = carouselProducts[i];
                <div class="carousel-item @(i == 0 ? "active" : string.Empty)">
                    <img src="@(item.ImageUrl ?? "https://placehold.co/1200x450")" class="d-block w-100" alt="@item.Name" style="height: 450px; object-fit: cover;" />
                    <div class="carousel-caption d-none d-md-block bg-dark bg-opacity-50 rounded p-3">
                        <h5>@item.Name</h5>
                        <p>@item.Description</p>
                        <a class="btn btn-light btn-sm" asp-controller="Products" asp-action="Details" asp-route-id="@item.Id">View</a>
                    </div>
                </div>
            }
        </div>
        <button class="carousel-control-prev" type="button" data-bs-target="#productCarousel" data-bs-slide="prev">
            <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Previous</span>
        </button>
        <button class="carousel-control-next" type="button" data-bs-target="#productCarousel" data-bs-slide="next">
            <span class="carousel-control-next-icon" aria-hidden="true"></span>
            <span class="visually-hidden">Next</span>
        </button>
    </section>
}

<h2 class="h4 mb-3">Featured Products</h2>
<div class="row g-3 mb-5">
@foreach (var item in Model.FeaturedProducts)
{
    <div class="col-md-4">
        <div class="card product-card h-100">
            <img class="card-img-top" src="@(item.ImageUrl ?? "https://placehold.co/600x350")" alt="@item.Name" />
            <div class="card-body d-flex flex-column">
                <h3 class="h5">@item.Name</h3>
                <p class="text-muted">@(item.Description ?? "No description")</p>
                <div class="mt-auto d-flex justify-content-between align-items-center">
                    <strong>$@item.Price</strong>
                    <div class="d-flex gap-2">
                        <a class="btn btn-outline-dark btn-sm" asp-controller="Products" asp-action="Details" asp-route-id="@item.Id">View</a>
                        @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Customer"))
                        {
                            <form asp-controller="Cart" asp-action="Add" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@item.Id" />
                                <input type="hidden" name="quantity" value="1" />
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                <button type="submit" class="btn btn-dark btn-sm">Add to Cart</button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}
</div>

@foreach (var group in Model.CategoryGroups)
{
    <section class="mb-5">
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h2 class="h4 mb-0">@group.CategoryName</h2>
            <a class="btn btn-outline-dark btn-sm" asp-controller="Products" asp-action="Index" asp-route-category="@group.CategorySlug">View all</a>
        </div>

        <div class="row g-3">
            @foreach (var item in group.Products)
            {
                <div class="col-md-3">
                    <div class="card product-card h-100">
                        <img class="card-img-top" src="@(item.ImageUrl ?? "https://placehold.co/500x300")" alt="@item.Name" />
                        <div class="card-body d-flex flex-column">
                            <h3 class="h6">@item.Name</h3>
                            <p class="text-muted small">@(item.Description ?? "No description")</p>
                            <div class="mt-auto d-flex justify-content-between align-items-center">
                                <strong>$@item.Price</strong>
                                <div class="d-flex gap-2">
                                    <a class="btn btn-outline-dark btn-sm" asp-controller="Products" asp-action="Details" asp-route-id="@item.Id">View</a>
                                    @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Customer"))
                                    {
                                        <form asp-controller="Cart" asp-action="Add" method="post" class="d-inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="productId" value="@item.Id" />
                                            <input type="hidden" name="quantity" value="1" />
                                            <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                                            <button type="submit" class="btn btn-dark btn-sm">Add to Cart</button>
                                        </form>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section>
}
