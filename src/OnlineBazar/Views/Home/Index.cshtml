@model OnlineBazar.ViewModels.HomeViewModel

@{
    ViewData["Title"] = "Home";
}

<section id="homeBannerCarousel" class="carousel slide shadow-sm rounded overflow-hidden" data-bs-ride="carousel">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#homeBannerCarousel" data-bs-slide-to="0" class="active" aria-current="true" aria-label="Banner 1"></button>
        <button type="button" data-bs-target="#homeBannerCarousel" data-bs-slide-to="1" aria-label="Banner 2"></button>
        <button type="button" data-bs-target="#homeBannerCarousel" data-bs-slide-to="2" aria-label="Banner 3"></button>
    </div>
    <div class="carousel-inner">
        <div class="carousel-item active">
            <img src="~/images/carousel/fashion-1.svg" class="d-block w-100" alt="Spring collection banner" />
        </div>
        <div class="carousel-item">
            <img src="~/images/carousel/fashion-2.svg" class="d-block w-100" alt="New arrivals banner" />
        </div>
        <div class="carousel-item">
            <img src="~/images/carousel/fashion-3.svg" class="d-block w-100" alt="Discount offers banner" />
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#homeBannerCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#homeBannerCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
        <span class="visually-hidden">Next</span>
    </button>
</section>

<section class="mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="h4 mb-0">Featured Products</h2>
        <a asp-controller="Products" asp-action="Index" class="btn btn-outline-dark btn-sm d-inline-flex align-items-center gap-2">
            <span>View More</span>
            <span aria-hidden="true">&rarr;</span>
        </a>
    </div>

    <div class="featured-products-row pb-2">
        @foreach (var product in Model.FeaturedProducts)
        {
            <article class="card product-card featured-product-card h-100">
                <img src="@(string.IsNullOrWhiteSpace(product.ImageUrl) ? Url.Content("~/images/carousel/fashion-1.svg") : product.ImageUrl)"
                     class="card-img-top product-card-image"
                     alt="@product.Name" />
                <div class="card-body">
                    <h3 class="h6 product-card-title">@product.Name</h3>
                    <p class="text-primary fw-semibold mb-3">$@product.Price.ToString("0.00")</p>
                    <a asp-controller="Products" asp-action="Details" asp-route-id="@product.Id" class="btn btn-sm btn-dark">View</a>
                </div>
            </article>
        }
    </div>
</section>
