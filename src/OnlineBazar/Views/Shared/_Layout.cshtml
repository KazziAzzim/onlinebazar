@inject OnlineBazar.Interfaces.ICartService CartService
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="OnlineBazar modern ecommerce platform" />
    <title>@ViewData["Title"] - OnlineBazar</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body>
    <header class="shadow-sm bg-white sticky-top">
        <nav class="navbar navbar-expand-lg container">
            <a class="navbar-brand fw-bold text-gradient" asp-controller="Home" asp-action="Index">OnlineBazar</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"><span class="navbar-toggler-icon"></span></button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav ms-auto gap-2 align-items-lg-center">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Products" asp-action="Index">Products</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="About">About</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Contact">Contact</a></li>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        @if (User.IsInRole("Customer"))
                        {
                            var cartCount = CartService.GetCartItemCount();
                            <li class="nav-item">
                                <a class="btn btn-outline-dark position-relative" asp-controller="Cart" asp-action="Index">
                                    Cart
                                    @if (cartCount > 0)
                                    {
                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                            @cartCount
                                        </span>
                                    }
                                </a>
                            </li>
                        }

                        <li class="nav-item">
                            <span class="nav-link text-muted">
                                @User.Identity.Name
                                @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                                {
                                    <span class="badge bg-dark ms-1">Admin</span>
                                }
                                else if (User.IsInRole("Customer"))
                                {
                                    <span class="badge bg-secondary ms-1">Customer</span>
                                }
                            </span>
                        </li>
                        <li class="nav-item">
                            <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                @Html.AntiForgeryToken()
                                <button class="btn btn-outline-secondary" type="submit">Logout</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="btn btn-outline-dark" asp-controller="Account" asp-action="Login">Login</a></li>
                        <li class="nav-item"><a class="btn btn-dark" asp-controller="Account" asp-action="Register">Register</a></li>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                    {
                        <li class="nav-item"><a class="btn btn-dark" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Admin</a></li>
                    }
                </ul>
            </div>
        </nav>
    </header>
    <main class="container py-4">@RenderBody()</main>
    <footer class="border-top py-4 text-center text-muted">© @DateTime.UtcNow.Year OnlineBazar</footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
