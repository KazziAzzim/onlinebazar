@inject OnlineBazar.Interfaces.ICartService CartService
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content="OnlineBazar modern ecommerce platform" />
    <title>@ViewData["Title"] - OnlineBazar</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body>
    <header class="shadow-sm bg-white sticky-top">
        <nav class="navbar navbar-expand-lg container">
            <a class="navbar-brand fw-bold text-gradient" asp-controller="Home" asp-action="Index">OnlineBazar</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav"><span class="navbar-toggler-icon"></span></button>
            <div class="collapse navbar-collapse" id="mainNav">
                <ul class="navbar-nav ms-auto gap-2 align-items-lg-center">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index">Home</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Products" asp-action="Index">Products</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="About">About</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Contact">Contact</a></li>

                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        var displayName = User.Identity?.Name ?? "User";
                        var avatarLetter = string.IsNullOrWhiteSpace(displayName) ? "U" : displayName[..1].ToUpperInvariant();

                        @if (User.IsInRole("Customer"))
                        {
                            var cartCount = CartService.GetCartItemCount();
                            <li class="nav-item">
                                <a class="nav-icon-button position-relative" asp-controller="Cart" asp-action="Index" title="My Cart" aria-label="My Cart">
                                    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
                                        <path d="M3 4H5L7.1 14.4C7.28 15.25 8.02 15.86 8.9 15.86H17.7C18.54 15.86 19.27 15.3 19.5 14.49L21 9H8.2" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
                                        <circle cx="9.5" cy="19" r="1.5" fill="currentColor" />
                                        <circle cx="17.5" cy="19" r="1.5" fill="currentColor" />
                                    </svg>
                                    @if (cartCount > 0)
                                    {
                                        <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                                            @cartCount
                                        </span>
                                    }
                                </a>
                            </li>
                        }

                        <li class="nav-item dropdown">
                            <a class="profile-trigger dropdown-toggle"
                               href="#"
                               role="button"
                                data-bs-toggle="dropdown"
                               aria-expanded="false"
                               title="User menu"
                               aria-label="User menu">
                                <span class="profile-avatar">@avatarLetter</span>
                            </a>
                            <ul class="dropdown-menu dropdown-menu-end shadow-sm">
                                <li><h6 class="dropdown-header">@displayName</h6></li>
                                <li><hr class="dropdown-divider"></li>
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile">Profile</a></li>
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="MyOrders">My Orders</a></li>
                                <li><a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword">Change Password</a></li>
                                <li><hr class="dropdown-divider"></li>
                                <li>
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                                        @Html.AntiForgeryToken()
                                        <button class="dropdown-item text-danger" type="submit">Logout</button>
                                    </form>
                                </li>
                            </ul>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="btn btn-outline-dark" asp-controller="Account" asp-action="Login">Login</a></li>
                        <li class="nav-item"><a class="btn btn-dark" asp-controller="Account" asp-action="Register">Register</a></li>
                    }

                    @if (User.IsInRole("Admin") || User.IsInRole("Manager"))
                    {
                        <li class="nav-item"><a class="btn btn-dark" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Admin</a></li>
                    }
                </ul>
            </div>
        </nav>
    </header>
    <main class="container py-4">@RenderBody()</main>
    <footer class="border-top py-4 text-center text-muted">© @DateTime.UtcNow.Year OnlineBazar</footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
