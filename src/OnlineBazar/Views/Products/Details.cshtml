@model ProductDto
@{ ViewData["Title"] = Model.Name; }
<div class="row g-4">
    <div class="col-md-6"><img class="img-fluid rounded" src="@(Model.ImageUrl ?? "https://placehold.co/700x450")" alt="@Model.Name" /></div>
    <div class="col-md-6">
        <h1>@Model.Name</h1>
        <p>@Model.Description</p>
        <p class="h4">$@Model.Price</p>
        <button class="btn btn-dark">Add to Cart</button>
    </div>
</div>
