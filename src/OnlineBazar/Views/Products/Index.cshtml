@model IEnumerable<ProductDto>
@{ ViewData["Title"] = "Catalog"; }
<h1>Product Catalog</h1>
<div class="row g-3">
@foreach (var item in Model)
{
    <div class="col-md-3">
        <div class="card product-card h-100">
            <img class="card-img-top" src="@(item.ImageUrl ?? "https://placehold.co/500x300")" alt="@item.Name" />
            <div class="card-body d-flex flex-column">
                <h2 class="h6">@item.Name</h2>
                <p class="text-muted small">@(item.Description ?? "No description")</p>
                <div class="mt-auto d-flex justify-content-between align-items-center">
                    <strong>$@item.Price</strong>
                    <div class="d-flex gap-2">
                        <a class="btn btn-outline-dark btn-sm" asp-action="Details" asp-route-id="@item.Id">View</a>
                        @if (User.Identity?.IsAuthenticated == true && User.IsInRole("Customer"))
                        {
                            <form asp-controller="Cart" asp-action="Add" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="productId" value="@item.Id" />
                                <input type="hidden" name="quantity" value="1" />
                                <input type="hidden" name="returnUrl" value="@Context.Request.Path@Context.Request.QueryString" />
                                <button type="submit" class="btn btn-dark btn-sm">Add</button>
                            </form>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
}
</div>
