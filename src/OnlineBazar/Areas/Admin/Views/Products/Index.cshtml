@model IEnumerable<ProductDto>
@{ ViewData["Title"] = "Manage Products"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Products</h1>
    <a class="btn btn-primary" asp-action="Create">New Product</a>
</div>
<table class="table table-bordered">
    <thead><tr><th>Name</th><th>Price</th><th>Stock</th><th></th></tr></thead>
    <tbody>
    @foreach (var p in Model)
    {
        <tr>
            <td>@p.Name</td><td>$@p.Price</td><td>@p.StockQuantity</td>
            <td>
                <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@p.Id">Edit</a>
                <form method="post" asp-action="Delete" asp-route-id="@p.Id" class="d-inline"><button class="btn btn-sm btn-outline-danger">Delete</button></form>
            </td>
        </tr>
    }
    </tbody>
</table>
