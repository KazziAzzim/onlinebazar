@model ProductDto
<h1>Edit Product</h1>
<form method="post" class="row g-3">
    <input type="hidden" asp-for="Id" />
    <div class="col-md-6"><label>Name</label><input asp-for="Name" class="form-control" /></div>
    <div class="col-md-6"><label>Slug</label><input asp-for="Slug" class="form-control" /></div>
    <div class="col-md-4"><label>Price</label><input asp-for="Price" class="form-control" /></div>
    <div class="col-md-4"><label>Stock</label><input asp-for="StockQuantity" class="form-control" /></div>
    <div class="col-md-4"><label>Category Id</label><input asp-for="CategoryId" class="form-control" /></div>
    <div class="col-12"><label>Description</label><textarea asp-for="Description" class="form-control"></textarea></div>
    <div class="col-12"><button class="btn btn-primary">Update</button></div>
</form>
