@model DashboardViewModel
@{ ViewData["Title"] = "Dashboard"; }
<h1>Dashboard</h1>
<div class="row g-3">
    <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted">Products</div><div class="h3">@Model.ProductCount</div></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted">Categories</div><div class="h3">@Model.CategoryCount</div></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted">Orders</div><div class="h3">@Model.OrdersCount</div></div></div></div>
    <div class="col-md-3"><div class="card"><div class="card-body"><div class="text-muted">Sales</div><div class="h3">$@Model.TotalSales</div></div></div></div>
</div>
