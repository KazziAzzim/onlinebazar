@model IEnumerable<CategoryDto>
@{ ViewData["Title"] = "Manage Categories"; }
<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3">Categories</h1>
    <a class="btn btn-primary" asp-action="Create">New Category</a>
</div>
<table class="table table-bordered">
    <thead><tr><th>Name</th><th>Slug</th><th></th></tr></thead>
    <tbody>
    @foreach (var c in Model)
    {
        <tr>
            <td>@c.Name</td><td>@c.Slug</td>
            <td>
                <a class="btn btn-sm btn-outline-secondary" asp-action="Edit" asp-route-id="@c.Id">Edit</a>
                <form method="post" asp-action="Delete" asp-route-id="@c.Id" class="d-inline"><button class="btn btn-sm btn-outline-danger">Delete</button></form>
            </td>
        </tr>
    }
    </tbody>
</table>
