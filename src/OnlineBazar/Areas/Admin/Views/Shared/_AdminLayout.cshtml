<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin - @ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
<div class="container-fluid">
    <div class="row">
        <aside class="col-md-2 bg-dark text-white min-vh-100 p-3">
            <h5>Admin Panel</h5>
            <a class="d-block text-white mb-2" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Dashboard</a>
            <a class="d-block text-white mb-2" asp-area="Admin" asp-controller="Products" asp-action="Index">Products</a>
            <a class="d-block text-white" asp-area="Admin" asp-controller="Categories" asp-action="Index">Categories</a>
        </aside>
        <main class="col-md-10 p-4">@RenderBody()</main>
    </div>
</div>
</body>
</html>
