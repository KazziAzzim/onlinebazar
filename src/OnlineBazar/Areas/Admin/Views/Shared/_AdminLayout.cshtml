@{
    var currentController = (ViewContext.RouteData.Values["controller"]?.ToString() ?? string.Empty).ToLowerInvariant();
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Admin - @ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />
</head>
<body>
<div class="container-fluid admin-shell">
    <div class="row g-0">
        <aside class="col-lg-2 col-md-3 admin-sidebar p-3 p-md-4">
            <h5 class="fw-semibold mb-4">Admin Panel</h5>
            <nav class="nav flex-column gap-2 admin-nav">
                <a class="admin-link @(currentController == "dashboard" ? "active" : "")" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">
                    Dashboard
                </a>
                <a class="admin-link @(currentController == "products" ? "active" : "")" asp-area="Admin" asp-controller="Products" asp-action="Index">
                    Products
                </a>
                <a class="admin-link @(currentController == "categories" ? "active" : "")" asp-area="Admin" asp-controller="Categories" asp-action="Index">
                    Categories
                </a>
            </nav>
        </aside>
        <main class="col-lg-10 col-md-9 p-4 p-md-5 admin-content">@RenderBody()</main>
    </div>
</div>
</body>
</html>
